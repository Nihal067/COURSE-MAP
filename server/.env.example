PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/coursemap
JWT_SECRET=replace-with-a-long-random-secret
REQUIRE_SIGNUP_OTP=false

# Comma-separated list of allowed browser origins.
# Example:
# CORS_ORIGIN=https://your-frontend-domain.vercel.app,http://localhost:3000
CORS_ORIGIN=

# Used by email templates for CTA links.
# Example:
# APP_URL=https://your-frontend-domain.vercel.app/dashboard
APP_URL=

# Required for signup OTP email verification.
EMAIL_USER=
EMAIL_PASS=
